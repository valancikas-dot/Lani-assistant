# ─────────────────────────────────────────────────────────────────────────────
# Personal AI Assistant – Orchestrator Service
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# Set to true to enable SQL query logging and verbose output
DEBUG=false

# Host / port for the FastAPI server
HOST=127.0.0.1
PORT=8000

# SQLite database path (relative to the orchestrator service root)
DATABASE_URL=sqlite+aiosqlite:///./assistant.db

# Comma-separated list of absolute paths the assistant is allowed to touch.
# Example: ALLOWED_DIRECTORIES_RAW=/Users/you/Desktop,/Users/you/Downloads
# Leave blank to deny all file operations (safe default).
ALLOWED_DIRECTORIES_RAW=

# OpenAI API key – leave blank to disable OpenAI-backed AI features
OPENAI_API_KEY=

# Optional Anthropic API key – if set, some chat/features may prefer Anthropic
ANTHROPIC_API_KEY=

# LLM models
LLM_MODEL=gpt-4.5-preview
AGENT_MODEL=o3
ROUTER_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-7-sonnet-20250219

# User language preference (BCP-47 tag)
PREFERRED_LANGUAGE=en

# Voice defaults
VOICE_PROVIDER=placeholder
STT_ENABLED=true
TTS_ENABLED=false
TTS_VOICE=default

# Security / connector secrets
CONNECTOR_ENCRYPTION_KEY=
# Sugeneruok: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SUCCESS_URL=https://vilca.site/tokens?payment=success
STRIPE_CANCEL_URL=https://vilca.site/tokens?payment=cancelled
